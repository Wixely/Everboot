{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Everboot": {
    "DataDirectory": "./data",
    "Http": {
      "Port": 8080,
      "BindAddress": "+"
    },
    "Tftp": {
      "Port": 69,
      "BindAddress": "0.0.0.0",
      "MaxBlockSize": 1468,
      "BlockTimeoutMs": 1500,
      "MaxRetries": 5,
      "MaxConcurrentTransfers": 64
    },
    "Dhcp": {
      "Enabled": true,
      "Port": 67,
      "BindAddress": "0.0.0.0",
      "ServerAddress": null,
      "UnicastReplyToSource": false,
      "BootFiles": {
        "Bios": "undionly.kpxe",
        "Uefi32": "snponly-i386.efi",
        "Uefi64": "snponly.efi",
        "UefiArm64": "snponly-arm64.efi"
      },
      "IpxeScriptUrl": "http://{server}/boot.ipxe"
    },
    "Iscsi": {
      "Enabled": true,
      "Port": 3260,
      "BindAddress": "0.0.0.0",
      "IqnBase": "iqn.2026-05.local.everboot",
      "MaxReceiveDataSegment": 262144,
      "UseForSanboot": false
    },
    "Smb": {
      "Enabled": true,
      "Port": 445,
      "BindAddress": "0.0.0.0",
      "ServerName": "EVERBOOT",
      "MaxReadSize": 1048576
    },
    "Menu": {
      "Title": "Everboot - select an image",
      "TimeoutSeconds": 60,
      "IncludeSanbootFallback": true
    }
  }
}
